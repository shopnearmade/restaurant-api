    {
      "name": "Orders",
      "description": "All endpoints for the Order collection. Tests CRUD, filtering by status, pagination, populate (relationship queries), and error cases. At least 3 requests demonstrate Order→Customer and Order→MenuItem relationships.",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "description": "Returns all orders with nested Customer name/email and MenuItem name/price populated."
          },
          "response": []
        },
        {
          "name": "Get All Orders - Filter by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders?status=Pending",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "Pending", "description": "Valid values: Pending, Preparing, Ready, Completed, Cancelled" }
              ]
            },
            "description": "Returns only orders with status 'Pending'."
          },
          "response": []
        },
        {
          "name": "Get All Orders - Paginated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders?page=1&limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Returns the first 5 orders. Demonstrates pagination on the orders collection."
          },
          "response": []
        },
        {
          "name": "Get Most Popular Menu Item",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/popular",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "popular"]
            },
            "description": "[Relationship] Traverses all orders and counts MenuItem occurrences to find the most frequently ordered item. Returns `{ item: name, count: number }`."
          },
          "response": []
        },
        {
          "name": "[Relationship] Get Order by ID - Populated Customer & Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/{{orderId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{orderId}}"]
            },
            "description": "[Relationship] Returns a single order with its Customer (name, email, phone) and each MenuItem (name, price, category) fully populated via ObjectId references — demonstrating the Order→Customer and Order→MenuItem relationships."
          },
          "response": []
        },
        {
          "name": "[Relationship] Create New Order (links Customer + Menu Items)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customerId}}\",\n  \"menuItem\": [\n    { \"item\": \"{{menuItemId}}\", \"quantity\": 2 }\n  ],\n  \"totalAmount\": 25.98,\n  \"status\": \"Pending\",\n  \"specialInstructions\": \"Extra sauce on the side please\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "description": "[Relationship] Creates an order that references a Customer ObjectId and a MenuItem ObjectId — demonstrating both relationships defined in the data model. Requires `customerId` and `menuItemId` collection variables to be set."
          },
          "response": []
        },
        {
          "name": "Update Order (Full)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customerId}}\",\n  \"menuItem\": [\n    { \"item\": \"{{menuItemId}}\", \"quantity\": 3 }\n  ],\n  \"totalAmount\": 38.97,\n  \"status\": \"Preparing\",\n  \"specialInstructions\": \"Updated: no sauce\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders/{{orderId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{orderId}}"]
            },
            "description": "Full replacement update of an order. Updates quantity and advances status to 'Preparing'."
          },
          "response": []
        },
        {
          "name": "Partial Update Order Status (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Ready\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders/{{orderId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{orderId}}"]
            },
            "description": "Partial update — advances the order status to 'Ready' without changing any other fields. Practical use case: kitchen marks order done."
          },
          "response": []
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/{{orderId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{orderId}}"]
            },
            "description": "Deletes the order with the given ID. Returns 404 if not found."
          },
          "response": []
        },
        {
          "name": "[Error] Get Order - Invalid ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/orders/invalidid123",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "invalidid123"]
            },
            "description": "Expects a 500 error because 'invalidid123' is not a valid MongoDB ObjectId."
          },
          "response": []
        },
        {
          "name": "[Error] Create Order - Missing Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"menuItem\": [\n    { \"item\": \"{{menuItemId}}\", \"quantity\": 1 }\n  ],\n  \"totalAmount\": 12.99,\n  \"status\": \"Pending\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"]
            },
            "description": "Expects a 400 validation error because the required `customer` field is missing."
          },
          "response": []
        },
        {
          "name": "[Error] Create Order - Invalid Status",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customerId}}\",\n  \"menuItem\": [\n    { \"item\": \"{{menuItemId}}\", \"quantity\": 1 }\n  ],\n  \"totalAmount\": 12.99,\n  \"status\": \"Flying\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/orders",
